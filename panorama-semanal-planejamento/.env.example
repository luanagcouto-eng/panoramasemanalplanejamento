# NextAuth / Google (decisao #9 — login via Google + allowlist `allowed_emails`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — credencial de aplicacao (app-only / client credentials)
# para a Fase 2 (consulta ao PWA via OData), independente do login do usuario.
# Definir ao iniciar a Fase 2.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project Settings > Data API > JWT Settings > JWT Secret (HS256, legacy)
# usado para assinar tokens "authenticated" no sync NextAuth -> auth.users
SUPABASE_JWT_SECRET=

# Sentry (Observabilidade — Fase 5)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# SharePoint / PWA (Fase 2)
SHAREPOINT_PWA_BASE_URL=
